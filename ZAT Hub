-- ================== CÀI ĐẶT ==================
local Settings = {
    AutoFarm = true,
    AutoQuest = true,
    AutoBuso = true,
    AutoHaki = true,
    FarmRadius = 200,           -- Bán kính farm
    FarmMethod = "Above",       -- Above / Below / Behind
    SelectedWeapon = "Melee",   -- Melee / Sword / Gun / Fruit
    TweenSpeed = 250,           -- Tốc độ di chuyển (cao quá dễ lag)
    AutoEatFruit = true,
    Webhook = ""                -- Dán webhook discord vào đây nếu muốn
}

-- ================== LOAD LIBRARY ==================
local Players = game:GetService("Players")
