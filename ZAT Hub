local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Anti-AFK
LocalPlayer.Idled:connect(function()
    game:GetService("VirtualUser"):Button2Down(Vector2.new(0,0),workspace.CurrentCamera.CFrame)
    wait(1)
    game:GetService("VirtualUser"):Button2Up(Vector2.new(0,0),workspace.CurrentCamera.CFrame)
end)

-- ================== HÀM CHÍNH ==================
function GetQuest()
    if not Settings.AutoQuest then return end
    local level = LocalPlayer.Data.Level.Value
    -- Tự động nhận quest phù hợp level
    for _, v in pairs(Workspace.NPCs:GetChildren()) do
        if v.Name:find("Quest") or v:FindFirstChild("Quest") then
            local dist = (v.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if dist < 30 then
                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("StartQuest", v.Name, 1)
                print("📜 Nhận quest từ " .. v.Name)
                break
            end
        end
    end
end

function FarmMob()
    if not Settings.AutoFarm then return end
    
    local mobs = {}
    for _, v in pairs(Workspace.Enemies:GetChildren()) do
        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and 
           (v.Name:find("Bandit") or v.Name:find("Pirate") or v.Name:find("Marine") or v.Name:find("Fishman") or true) then
            table.insert(mobs, v)
        end
    end
    
    if #mobs > 0 then
        local closest = mobs[1]
        for _, mob in pairs(mobs) do
            local dist1 = (mob.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            local dist2 = (closest.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if dist1 < dist2 then closest = mob end
        end
        
        -- Di chuyển + farm
        local root = LocalPlayer.Character.HumanoidRootPart
        local targetPos = closest.HumanoidRootPart.Position
        
        if Settings.FarmMethod == "Above" then
            targetPos = targetPos + Vector3.new(0, Settings.FarmRadius/2, 0)
        elseif Settings.FarmMethod == "Below" then
            targetPos = targetPos - Vector3.new(0, 10, 0)
        end
        
        local tween = TweenService:Create(root, TweenInfo.new(
            (root.Position - targetPos).Magnitude / Settings.TweenSpeed, 
            Enum.EasingStyle.Linear
        ), {CFrame = CFrame.new(targetPos)})
        tween:Play()
        wait(0.1)
        
        -- Attack
        if LocalPlayer.Character:FindFirstChildOfClass("Tool") then
            LocalPlayer.Character:FindFirstChildOfClass("Tool"):Activate()
        end
    end
end

-- Auto Buso + Haki
spawn(function()
    while wait(5) do
        if Settings.AutoBuso then
            pcall(function()
                ReplicatedStorage.Remotes.CommF_:InvokeServer("Buso")
            end)
        end
        if Settings.AutoHaki then
            pcall(function()
                ReplicatedStorage.Remotes.CommE:FireServer("Haki")
            end)
        end
    end
end)

-- ================== MAIN LOOP ==================
spawn(function()
    while wait(0.3) do
        pcall(function()
            if Settings.AutoFarm then
                GetQuest()
                FarmMob()
            end
        end)
    end
end)

